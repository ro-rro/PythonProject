Missing dates were then replaced observed release dates. This preserves the overall distribution of release dates while also making sure that there is value in the release data column.

set.seed(123)

missing_row <- which(is.na(data$release_date))

observed_dates <- data$release_date[!is.na(data$release_date)]

data$release_date[missing_row] <- sample(
  observed_dates, 
  size = length(missing_row), 
  replace = TRUE
  )
